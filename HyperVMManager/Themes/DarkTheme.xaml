<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="BackgroundColor">#0D1117</Color>
  <Color x:Key="SurfaceColor">#161B22</Color>
  <Color x:Key="CardColor">#1C2333</Color>
  <Color x:Key="BorderColor">#30363D</Color>
  <Color x:Key="AccentColor">#58A6FF</Color>
  <Color x:Key="AccentHoverColor">#79B8FF</Color>
  <Color x:Key="SuccessColor">#3FB950</Color>
  <Color x:Key="WarningColor">#D29922</Color>
  <Color x:Key="DangerColor">#F85149</Color>
  <Color x:Key="TextPrimaryColor">#E6EDF3</Color>
  <Color x:Key="TextSecondaryColor">#8B949E</Color>
  <Color x:Key="HeaderGradientStart">#1A2332</Color>
  <Color x:Key="HeaderGradientEnd">#0D1117</Color>
  <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}" />
  <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
  <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
  <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
  <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
  <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
  <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
  <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
  <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
  <Style x:Key="MainWindowStyle" TargetType="{x:Type Window}">
    <Setter Property="Background" Value="{StaticResource BackgroundBrush}" />
  </Style>
  <Style x:Key="DataGridStyle" TargetType="{x:Type DataGrid}">
    <Setter Property="Background" Value="#00FFFFFF" />
    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    <Setter Property="BorderBrush" Value="#00FFFFFF" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="DataGrid.GridLinesVisibility" Value="None" />
    <Setter Property="DataGrid.RowBackground" Value="#00FFFFFF" />
    <Setter Property="DataGrid.AlternatingRowBackground" Value="#00FFFFFF" />
    <Setter Property="DataGrid.HeadersVisibility" Value="None" />
    <Setter Property="DataGrid.SelectionUnit" Value="FullRow" />
    <Setter Property="DataGrid.IsReadOnly" Value="True" />
    <Setter Property="DataGrid.AutoGenerateColumns" Value="False" />
    <Setter Property="DataGrid.CanUserAddRows" Value="False" />
    <Setter Property="DataGrid.CanUserDeleteRows" Value="False" />
    <Setter Property="DataGrid.CanUserResizeRows" Value="False" />
    <Setter Property="DataGrid.RowHeight" Value="88" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontFamily" Value="Segoe UI" />
    <Setter Property="DataGrid.SelectionMode" Value="Single" />
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="Padding" Value="8,10,8,12" />
  </Style>
  <Style x:Key="DataGridColumnHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
    <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
    <Setter Property="Foreground" Value="#B1BAC4" />
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="14,10" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="0,0,1,1" />
  </Style>
  <Style x:Key="DataGridRowStyle" TargetType="{x:Type DataGridRow}">
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Background" Value="#161B22" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type DataGridRow}">
          <Border Name="RowCard" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="12" Margin="12,9,12,9" SnapsToDevicePixels="True">
            <DataGridCellsPresenter Name="PART_CellPresenter" ItemsPanel="{TemplateBinding DataGridRow.ItemsPanel}" SnapsToDevicePixels="{TemplateBinding UIElement.SnapsToDevicePixels}" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <DataTrigger Value="False" Binding="{Binding IsRunning}">
        <Setter Property="UIElement.Opacity" Value="0.72" />
      </DataTrigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="UIElement.IsMouseOver" Value="True" />
          <Condition Property="DataGridRow.IsSelected" Value="False" />
        </MultiTrigger.Conditions>
        <Setter Property="Background" Value="#1C2430" />
        <Setter Property="BorderBrush" Value="#484F58" />
      </MultiTrigger>
      <Trigger Property="DataGridRow.IsSelected" Value="True">
        <Setter Property="Background" Value="#15253D" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
      </Trigger>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="UIElement.IsMouseOver" Value="True" />
          <Condition Property="DataGridRow.IsSelected" Value="True" />
        </MultiTrigger.Conditions>
        <Setter Property="Background" Value="#1A335C" />
      </MultiTrigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="DataGridCellStyle" TargetType="{x:Type DataGridCell}">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="16,10" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type DataGridCell}">
          <Border Background="#00FFFFFF" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True">
            <ContentPresenter VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="DataGridCell.IsSelected" Value="True">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>
  <Style x:Key="ActionButton" TargetType="{x:Type Button}">
    <Setter Property="Background" Value="{StaticResource AccentBrush}" />
    <Setter Property="Foreground" Value="#FFFFFF" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="20,10" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="FrameworkElement.Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Border Background="{TemplateBinding Control.Background}" CornerRadius="8" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="UIElement.IsMouseOver" Value="True">
              <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter Property="Background" Value="#30363D" />
              <Setter Property="Foreground" Value="#8B949E" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="StatCard" TargetType="{x:Type Border}">
    <Setter Property="Background" Value="{StaticResource CardBrush}" />
    <Setter Property="Border.CornerRadius" Value="12" />
    <Setter Property="Border.Padding" Value="20,16" />
    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
  </Style>
  <SolidColorBrush x:Key="ScrollTrackBrush" Color="#151A21" />
  <SolidColorBrush x:Key="ScrollThumbBrush" Color="#3D4450" />
  <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#585F6B" />
  <ControlTemplate x:Key="DarkScrollBarVertical" TargetType="{x:Type ScrollBar}">
    <Grid SnapsToDevicePixels="True">
      <Border CornerRadius="4" Margin="2,4,1,4" Background="{StaticResource ScrollTrackBrush}" />
      <Track Name="PART_Track" IsDirectionReversed="True" Focusable="False">
        <Track.DecreaseRepeatButton>
          <RepeatButton Command="{x:Static ScrollBar.LineUpCommand}" Opacity="0" Focusable="False" Height="0" Width="0" />
        </Track.DecreaseRepeatButton>
        <Track.IncreaseRepeatButton>
          <RepeatButton Command="{x:Static ScrollBar.LineDownCommand}" Opacity="0" Focusable="False" Height="0" Width="0" />
        </Track.IncreaseRepeatButton>
        <Track.Thumb>
          <Thumb>
            <Control.Template>
              <ControlTemplate TargetType="{x:Type Thumb}">
                <Border Name="T" CornerRadius="4" Margin="3,2,2,2" MinHeight="24" Background="{StaticResource ScrollThumbBrush}" />
                <ControlTemplate.Triggers>
                  <Trigger Property="UIElement.IsMouseOver" Value="True">
                    <Setter TargetName="T" Property="Border.Background" Value="{StaticResource ScrollThumbHoverBrush}" />
                  </Trigger>
                  <Trigger Property="Thumb.IsDragging" Value="True">
                    <Setter TargetName="T" Property="Border.Background" Value="#6E7681" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Control.Template>
          </Thumb>
        </Track.Thumb>
      </Track>
    </Grid>
  </ControlTemplate>
  <ControlTemplate x:Key="DarkScrollBarHorizontal" TargetType="{x:Type ScrollBar}">
    <Grid SnapsToDevicePixels="True">
      <Border CornerRadius="4" Margin="4,2,4,1" Background="{StaticResource ScrollTrackBrush}" />
      <Track Name="PART_Track" IsDirectionReversed="False" Focusable="False">
        <Track.DecreaseRepeatButton>
          <RepeatButton Command="{x:Static ScrollBar.LineLeftCommand}" Opacity="0" Focusable="False" Height="0" Width="0" />
        </Track.DecreaseRepeatButton>
        <Track.IncreaseRepeatButton>
          <RepeatButton Command="{x:Static ScrollBar.LineRightCommand}" Opacity="0" Focusable="False" Height="0" Width="0" />
        </Track.IncreaseRepeatButton>
        <Track.Thumb>
          <Thumb>
            <Control.Template>
              <ControlTemplate TargetType="{x:Type Thumb}">
                <Border Name="T" CornerRadius="4" Margin="2,3,2,2" MinWidth="24" Background="{StaticResource ScrollThumbBrush}" />
                <ControlTemplate.Triggers>
                  <Trigger Property="UIElement.IsMouseOver" Value="True">
                    <Setter TargetName="T" Property="Border.Background" Value="{StaticResource ScrollThumbHoverBrush}" />
                  </Trigger>
                  <Trigger Property="Thumb.IsDragging" Value="True">
                    <Setter TargetName="T" Property="Border.Background" Value="#6E7681" />
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Control.Template>
          </Thumb>
        </Track.Thumb>
      </Track>
    </Grid>
  </ControlTemplate>
  <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}">
    <Setter Property="UIElement.SnapsToDevicePixels" Value="True" />
    <Setter Property="FrameworkElement.OverridesDefaultStyle" Value="True" />
    <Setter Property="Background" Value="#00FFFFFF" />
    <Setter Property="Width" Value="10" />
    <Setter Property="Height" Value="Auto" />
    <Setter Property="MinWidth" Value="10" />
    <Setter Property="MinHeight" Value="10" />
    <Setter Property="Template" Value="{StaticResource DarkScrollBarVertical}" />
    <Style.Triggers>
      <Trigger Property="ScrollBar.Orientation" Value="Horizontal">
        <Setter Property="Width" Value="Auto" />
        <Setter Property="Height" Value="10" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="10" />
        <Setter Property="Template" Value="{StaticResource DarkScrollBarHorizontal}" />
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>