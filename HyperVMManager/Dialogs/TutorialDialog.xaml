<Window x:Class="HyperVMManager.Dialogs.TutorialDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VENOM VM-WARE Tips"
        Width="540" SizeToContent="Height" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#00FFFFFF"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True">
  <Border CornerRadius="12" Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" Margin="16" ClipToBounds="True">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Background="#161B22" Padding="16,13" BorderBrush="#30363D" BorderThickness="0,0,0,1" MouseLeftButtonDown="Header_MouseLeftButtonDown">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Width="30" Height="30" Background="#18351F" CornerRadius="7">
            <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" Foreground="#3FB950" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Grid.Column="1" Text="VENOM VM-WARE Tips" Foreground="#F0F6FC" FontSize="16" FontWeight="SemiBold" FontFamily="Segoe UI" Margin="12,0,0,0" VerticalAlignment="Center" />
        </Grid>
      </Border>
      <StackPanel Grid.Row="1" Margin="20,18,20,8">
        <TextBlock Text="IPv4 pool" Foreground="#58A6FF" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBlock Text="Set the guest IPv4 range from the network button. New Ubuntu VMs use the next free address from that pool." Foreground="#B1BAC4" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,5,0,14" />

        <TextBlock Text="Suggested IP" Foreground="#58A6FF" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBlock Text="The suggested IP is calculated from existing VMs, ping checks, cached reservations, and manual exclusions." Foreground="#B1BAC4" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,5,0,14" />

        <TextBlock Text="Ubuntu cloud image" Foreground="#58A6FF" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBlock Text="The app downloads the official compressed Ubuntu cloud image archive into its shared cache, verifies it, then extracts a VM disk when you create a machine." Foreground="#B1BAC4" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,5,0,14" />

        <TextBlock Text="Disk path" Foreground="#58A6FF" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBlock Text="Use Auto to place VM disks under the app install folder, or choose a custom base folder before creating the VM. Select a VM later to copy or open its disk folder." Foreground="#B1BAC4" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,5,0,14" />

        <TextBlock Text="Dynamic disk growth" Foreground="#58A6FF" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBlock Text="A dynamic virtual disk starts small, but the physical file grows as the guest OS writes data. Keep the disk limit close to what the workload really needs." Foreground="#B1BAC4" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,5,0,14" />

        <TextBlock Text="CPU and memory" Foreground="#58A6FF" FontSize="13" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBlock Text="Memory uses Hyper-V Dynamic Memory with a low startup value and a chosen maximum. CPU is shared by Hyper-V scheduling; vCPU count controls how many processors the guest can see." Foreground="#B1BAC4" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,5,0,0" />
      </StackPanel>
      <Border Grid.Row="2" Padding="16,8,16,16">
        <Button Content="Got it" Width="96" HorizontalAlignment="Right" Click="CloseButton_Click"
                Background="#238636" BorderBrush="#2EA043" Foreground="#FFFFFF" FontWeight="SemiBold"
                Padding="14,9" BorderThickness="1" Cursor="Hand" />
      </Border>
    </Grid>
  </Border>
</Window>
