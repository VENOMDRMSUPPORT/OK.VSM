  <Window x:Class="HyperVMManager.Dialogs.NetworkSettingsDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="IPv4 pool" Width="480" SizeToContent="Height" MinHeight="480" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True" Background="#00FFFFFF" ShowInTaskbar="False" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display" xmlns:dialogs="clr-namespace:HyperVMManager.Dialogs;assembly=HyperVMManager">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/HyperVMManager;component/Themes/DarkTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <Style x:Key="DialogIconBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="#00FFFFFF" CornerRadius="6" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#2D333B" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="PoolField" TargetType="{x:Type TextBox}">
        <Setter Property="Background" Value="#0D1117" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,8" />
        <Setter Property="FontFamily" Value="Consolas" />
        <Setter Property="FontSize" Value="13" />
      </Style>
      <Style x:Key="PoolBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#21262D" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="22,10" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#30363D" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="PoolPrimaryBtn" TargetType="{x:Type Button}" BasedOn="{StaticResource PoolBtn}">
        <Setter Property="Background" Value="#238636" />
        <Setter Property="BorderBrush" Value="#2EA043" />
        <Setter Property="Foreground" Value="#FFFFFF" />
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Border CornerRadius="12" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="16" SnapsToDevicePixels="True" ClipToBounds="True">
    <UIElement.Effect>
      <DropShadowEffect BlurRadius="24" ShadowDepth="3" Opacity="0.45" Direction="270" Color="#000000" />
    </UIElement.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Background="#161B22" CornerRadius="12,12,0,0" Padding="14,12" BorderBrush="#30363D" BorderThickness="0,0,0,1" MouseLeftButtonDown="Header_MouseLeftButtonDown">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Border Background="#1A2332" CornerRadius="6" Padding="6,4" VerticalAlignment="Center">
            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#58A6FF" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Grid.Column="1" Text="Guest IPv4 pool" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" FontFamily="Segoe UI" />
          <Button Grid.Column="2" Style="{StaticResource DialogIconBtn}" ToolTipService.ToolTip="Close" Click="CloseButton_Click">
            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#8B949E" />
          </Button>
        </Grid>
      </Border>
      <StackPanel Grid.Row="1" Margin="20,18,20,8">
        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontFamily="Segoe UI" LineHeight="18" Text="The next free IPv4 is computed from this range (ping + VMs in range + provisioning reservations). New Ubuntu cloud VMs get a static address from the pool using the gateway, prefix, and DNS below." />
        <TextBlock Margin="0,14,0,4" Text="Range start" FontSize="10" Foreground="#6E7681" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBox Name="TxtStart" Style="{StaticResource PoolField}" />
        <TextBlock Margin="0,12,0,4" Text="Range end" FontSize="10" Foreground="#6E7681" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBox Name="TxtEnd" Style="{StaticResource PoolField}" />
        <TextBlock Margin="0,12,0,4" Text="Default gateway" FontSize="10" Foreground="#6E7681" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBox Name="TxtGateway" Style="{StaticResource PoolField}" />
        <TextBlock Margin="0,12,0,4" Text="Prefix length (CIDR)" FontSize="10" Foreground="#6E7681" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBox Name="TxtPrefix" Style="{StaticResource PoolField}" />
        <TextBlock Margin="0,12,0,4" Text="DNS servers (comma-separated IPv4)" FontSize="10" Foreground="#6E7681" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBox Name="TxtDns" Style="{StaticResource PoolField}" />
        <TextBlock Margin="0,12,0,4" Text="Always exclude from next IPv4 (comma-separated, optional)" FontSize="10" Foreground="#6E7681" FontWeight="SemiBold" FontFamily="Segoe UI" />
        <TextBox Name="TxtManualExclusions" Style="{StaticResource PoolField}" />
      </StackPanel>
      <Border Grid.Row="2" Padding="16,8,16,16">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="Cancel" Style="{StaticResource PoolBtn}" MinWidth="88" IsCancel="True" Click="CancelButton_Click" />
          <Button Content="Save" Style="{StaticResource PoolPrimaryBtn}" MinWidth="88" Margin="10,0,0,0" IsDefault="True" Click="SaveButton_Click" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>