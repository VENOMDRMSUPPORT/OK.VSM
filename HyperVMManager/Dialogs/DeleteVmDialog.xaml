<Window x:Class="HyperVMManager.Dialogs.DeleteVmDialog" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Delete VM" Width="460" SizeToContent="Height" MinHeight="220" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True" Background="#00FFFFFF" ShowInTaskbar="False" SnapsToDevicePixels="True" TextOptions.TextFormattingMode="Display" xmlns:dialogs="clr-namespace:HyperVMManager.Dialogs;assembly=HyperVMManager">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/HyperVMManager;component/Themes/DarkTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <Style x:Key="DialogIconBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="#00FFFFFF" CornerRadius="6" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#2D333B" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="DeleteNoBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#21262D" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="22,10" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#30363D" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#161B22" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="DeleteYesBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#B62324" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="22,10" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="{TemplateBinding Control.Background}" CornerRadius="8" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#D03530" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#8B1E1F" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Border CornerRadius="12" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="16" SnapsToDevicePixels="True" ClipToBounds="True">
    <UIElement.Effect>
      <DropShadowEffect BlurRadius="24" ShadowDepth="3" Opacity="0.45" Direction="270" Color="#000000" />
    </UIElement.Effect>
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Border Grid.Row="0" Background="#161B22" CornerRadius="12,12,0,0" Padding="14,12" BorderBrush="#30363D" BorderThickness="0,0,0,1" MouseLeftButtonDown="Header_MouseLeftButtonDown">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Border Background="#3D1F24" CornerRadius="6" Padding="6,4" VerticalAlignment="Center">
            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#F85149" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <TextBlock Grid.Column="1" Text="Delete VM" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="12,0,0,0" FontFamily="Segoe UI" />
          <Button Grid.Column="2" Style="{StaticResource DialogIconBtn}" ToolTipService.ToolTip="Close" Click="CloseButton_Click">
            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#8B949E" />
          </Button>
        </Grid>
      </Border>
      <Grid Row="1" Margin="20,18,20,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="34" Foreground="{StaticResource WarningBrush}" VerticalAlignment="Top" Margin="2,0,0,0" />
        <StackPanel Grid.Column="1" Margin="16,0,0,0">
          <TextBlock FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" FontFamily="Segoe UI" LineHeight="22">
            <Run Text="Permanently delete virtual machine " /> <Run Name="VmNameRun" FontWeight="Bold" Foreground="#F0F6FC" Text="" /> <Run Text="?" /></TextBlock>
          <TextBlock Margin="0,10,0,0" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" FontFamily="Segoe UI" LineHeight="18">
            <Run Text="This removes the VM configuration from Hyper-V. Virtual disks are " /> <Run Text="not" FontWeight="Bold" Foreground="#C9D1D9" /> <Run Text=" deleted by default unless you remove them separately." /></TextBlock>
        </StackPanel>
      </Grid>
      <Border Grid.Row="2" Padding="16,8,16,16">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button Content="No" Style="{StaticResource DeleteNoBtn}" MinWidth="88" IsCancel="True" IsDefault="True" Click="NoButton_Click" />
          <Button Content="Yes" Style="{StaticResource DeleteYesBtn}" MinWidth="88" Margin="10,0,0,0" Click="YesButton_Click" />
        </StackPanel>
      </Border>
    </Grid>
  </Border>
</Window>