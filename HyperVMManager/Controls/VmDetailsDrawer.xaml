<UserControl x:Class="HyperVMManager.Controls.VmDetailsDrawer" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:converters="clr-namespace:HyperVMManager.Converters" SnapsToDevicePixels="True" xmlns:controls="clr-namespace:HyperVMManager.Controls" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/HyperVMManager;component/Themes/DarkTheme.xaml" />
      </ResourceDictionary.MergedDictionaries>
      <BooleanToVisibilityConverter x:Key="BoolToVis" />
      <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
      <Style x:Key="DrawerIconBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="#00FFFFFF" CornerRadius="6" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#2D333B" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="QuickActionBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#4021262D" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="12,14" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="{TemplateBinding Control.HorizontalContentAlignment}" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#2D3848" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Bd" Property="UIElement.Opacity" Value="0.45" />
                  <Setter Property="FrameworkElement.Cursor" Value="Arrow" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="DangerOutlineBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#2A1518" />
        <Setter Property="Foreground" Value="#F85149" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="BorderBrush" Value="#6E2A2D" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="{TemplateBinding Control.Background}" BorderBrush="{TemplateBinding Control.BorderBrush}" BorderThickness="{TemplateBinding Control.BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Control.Padding}" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#3D1F24" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter TargetName="Bd" Property="UIElement.Opacity" Value="0.4" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="DangerSolidBtn" TargetType="{x:Type Button}" BasedOn="{StaticResource DangerOutlineBtn}">
        <Setter Property="Background" Value="#8B1E1F" />
        <Setter Property="Foreground" Value="#FFFFFF" />
        <Setter Property="BorderBrush" Value="#B62324" />
      </Style>
      <Style x:Key="CopyMiniBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="#00FFFFFF" CornerRadius="4" SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#30363D" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <Grid VerticalAlignment="Stretch">
    <Grid Background="#06080C" Visibility="{Binding HasSelectedVm, Converter={StaticResource InverseBoolToVis}}" VerticalAlignment="Stretch">
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="28">
        <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="52" Foreground="#2A3038" HorizontalAlignment="Center" />
        <TextBlock Text="Select a virtual machine" FontSize="15" FontWeight="SemiBold" Foreground="#B1BAC4" HorizontalAlignment="Center" Margin="0,16,0,6" FontFamily="Segoe UI" />
        <TextBlock Text="Choose a row in the list to view details, network info, resource allocation, and actions." FontSize="12" Foreground="#6E7681" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="300" LineHeight="18" FontFamily="Segoe UI" />
      </StackPanel>
    </Grid>
    <Border Background="#0C1118" Visibility="{Binding HasSelectedVm, Converter={StaticResource BoolToVis}}" VerticalAlignment="Stretch">
      <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,2,0" Background="#00FFFFFF" VerticalAlignment="Stretch" VerticalContentAlignment="Top">
        <StackPanel Margin="0,0,0,28">
          <!-- Sidebar header: framed card, no install/OS hint banners -->
          <Border Margin="16,18,16,12" CornerRadius="14" SnapsToDevicePixels="True">
            <Border.BorderBrush>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#3D4F68" Offset="0" />
                <GradientStop Color="#252D3A" Offset="1" />
              </LinearGradientBrush>
            </Border.BorderBrush>
            <Border BorderThickness="1" CornerRadius="14" Background="#0E141D">
              <Grid>
                <Border VerticalAlignment="Top" Height="3" Margin="16,0,16,0" CornerRadius="2" Background="#58A6FF" Opacity="0.95" />
                <Grid Margin="18,16,18,18">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="VM DETAILS" FontSize="10" FontWeight="SemiBold" Foreground="#7D8590" FontFamily="Segoe UI" />
                  <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,12,8,0">
                    <Border Width="46" Height="46" CornerRadius="12" Background="#151C28" BorderBrush="#2D3748" BorderThickness="1" SnapsToDevicePixels="True">
                      <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe MDL2 Assets" FontSize="24" Text="&#xE912;">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#8B949E" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding SelectedVm.EnabledState}" Value="2">
                                <Setter Property="Foreground" Value="#3FB950" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding SelectedVm.EnabledState}" Value="3">
                                <Setter Property="Foreground" Value="#8B949E" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding SelectedVm.EnabledState}" Value="32768">
                                <Setter Property="Foreground" Value="#F85149" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding SelectedVm.EnabledState}" Value="32769">
                                <Setter Property="Foreground" Value="#F85149" />
                              </DataTrigger>
                              <DataTrigger Binding="{Binding SelectedVm.IsInstalling}" Value="True">
                                <Setter Property="Foreground" Value="#58A6FF" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                    </Border>
                    <StackPanel VerticalAlignment="Center" MinWidth="0" Margin="14,0,0,0">
                      <TextBlock FontSize="20" FontWeight="Bold" Foreground="#F0F6FC" FontFamily="Segoe UI" TextTrimming="CharacterEllipsis"
                                 Text="{Binding SelectedVm.Name}" ToolTipService.ToolTip="{Binding SelectedVm.Name}" />
                      <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Border CornerRadius="8" Padding="10,5" Background="#152018" BorderBrush="#2D6A3E" BorderThickness="1" Visibility="{Binding SelectedVm.IsRunning, Converter={StaticResource BoolToVis}}">
                          <TextBlock Text="Running" FontSize="12" FontWeight="SemiBold" Foreground="#3FB950" FontFamily="Segoe UI" />
                        </Border>
                        <Border CornerRadius="8" Padding="10,5" Background="#221418" BorderBrush="#6E2A2D" BorderThickness="1" Visibility="{Binding SelectedVm.IsRunning, Converter={StaticResource InverseBoolToVis}}">
                          <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#F85149" FontFamily="Segoe UI" Text="{Binding SelectedVm.StatusDisplay}" />
                        </Border>
                      </StackPanel>
                    </StackPanel>
                  </StackPanel>
                  <Button Grid.Row="1" Grid.Column="1" VerticalAlignment="Top" Margin="0,12,0,0" Style="{StaticResource DrawerIconBtn}" ToolTipService.ToolTip="Clear selection" Command="{Binding ClearSelectionCommand}">
                    <TextBlock Text="&#xE106;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#8B949E" />
                  </Button>
                </Grid>
              </Grid>
            </Border>
          </Border>
          <TextBlock Text="QUICK ACTIONS" FontSize="10" FontWeight="SemiBold" Foreground="#6E7681" Margin="16,6,16,8" FontFamily="Segoe UI" />
          <UniformGrid Rows="2" Columns="2" Margin="12,0,12,0">
            <Button Style="{StaticResource QuickActionBtn}" Margin="4" ToolTipService.ToolTip="Open Hyper-V VM Connection" Command="{Binding OpenVmConsoleCommand}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#58A6FF" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Open Console" TextWrapping="Wrap" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource QuickActionBtn}" Margin="4" IsEnabled="False" ToolTipService.ToolTip="Not available for local Hyper-V (cloud / guest agent feature).">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#8B949E" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Reset Password" TextWrapping="Wrap" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource QuickActionBtn}" Margin="4" ToolTipService.ToolTip="Create a checkpoint (snapshot)" Command="{Binding CreateSnapshotCommand}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#D29922" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="Create Snapshot" TextWrapping="Wrap" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource QuickActionBtn}" Margin="4" ToolTipService.ToolTip="Where to read allocation vs host" Command="{Binding ViewMetricsCommand}">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="16" Foreground="#A371F7" Margin="0,0,10,0" VerticalAlignment="Center" />
                <TextBlock Text="View Metrics" TextWrapping="Wrap" VerticalAlignment="Center" />
              </StackPanel>
            </Button>
          </UniformGrid>
          <TextBlock Text="NETWORK" FontSize="10" FontWeight="SemiBold" Foreground="#6E7681" Margin="16,20,16,8" FontFamily="Segoe UI" />
          <Border Margin="16,0,16,0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14,12" MinHeight="100">
            <Grid>
              <StackPanel Visibility="{Binding IsDrawerNetworkLoading, Converter={StaticResource InverseBoolToVis}}">
                <Grid Margin="0,0,0,12">
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid Row="0">
                    <TextBlock Text="IPv4" FontSize="10" Foreground="#6E7681" FontFamily="Segoe UI" VerticalAlignment="Center" />
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource CopyMiniBtn}" ToolTipService.ToolTip="Copy IPv4" Command="{Binding CopyDrawerIpv4Command}">
                      <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#8B949E" />
                    </Button>
                  </Grid>
                  <TextBlock Grid.Row="1" Margin="0,6,0,0" FontSize="13" Foreground="#F0F6FC" TextWrapping="Wrap" FontFamily="Consolas" VerticalAlignment="Top" MinHeight="20" Text="{Binding DrawerIpv4}" />
                </Grid>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>
                  <Grid Row="0">
                    <TextBlock Text="MAC Address" FontSize="10" Foreground="#6E7681" FontFamily="Segoe UI" VerticalAlignment="Center" />
                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource CopyMiniBtn}" ToolTipService.ToolTip="Copy MAC" Command="{Binding CopyDrawerMacCommand}">
                      <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#8B949E" />
                    </Button>
                  </Grid>
                  <TextBlock Grid.Row="1" Margin="0,6,0,0" FontSize="13" Foreground="#F0F6FC" TextWrapping="Wrap" FontFamily="Consolas" VerticalAlignment="Top" MinHeight="20" Text="{Binding DrawerMac}" />
                </Grid>
              </StackPanel>
              <Border Background="#99161B22" CornerRadius="8" Visibility="{Binding IsDrawerNetworkLoading, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12">
                  <ProgressBar IsIndeterminate="True" Height="3" Width="160" Foreground="#58A6FF" Background="#21262D" BorderThickness="0" />
                  <TextBlock Text="Loading network…" Foreground="#9DA7AF" FontSize="12" Margin="0,10,0,0" HorizontalAlignment="Center" FontFamily="Segoe UI" />
                </StackPanel>
              </Border>
            </Grid>
          </Border>
          <TextBlock Text="RESOURCE ALLOCATION" FontSize="10" FontWeight="SemiBold" Foreground="#6E7681" Margin="16,20,16,8" FontFamily="Segoe UI" />
          <Border Margin="16,0,16,0" Background="{StaticResource CardBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14,12">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="vCPU" FontSize="11" Foreground="#9DA7AF" Width="72" FontFamily="Segoe UI" />
                <TextBlock FontSize="13" Foreground="#F0F6FC" FontFamily="Segoe UI" Text="{Binding SelectedVm.CpuCount, StringFormat={}{0} logical processors (configured)}" />
              </StackPanel>
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="Memory" FontSize="11" Foreground="#9DA7AF" Width="72" FontFamily="Segoe UI" />
                <TextBlock FontSize="13" Foreground="#F0F6FC" FontFamily="Segoe UI" Text="{Binding SelectedVm.Memory}" />
              </StackPanel>
            </StackPanel>
          </Border>
          <TextBlock Text="DANGER ZONE" FontSize="10" FontWeight="SemiBold" Foreground="#F85149" Margin="16,20,16,8" FontFamily="Segoe UI" />
          <StackPanel Margin="16,0,16,8">
            <Button Style="{StaticResource DangerOutlineBtn}" HorizontalAlignment="Stretch" IsEnabled="False" Margin="0,0,0,8" ToolTipService.ToolTip="Rebuild / reinstall guest OS is not exposed as a single action in local Hyper-V. Use installation media inside the VM or replace the VHD.">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                <TextBlock Text="Rebuild OS" />
              </StackPanel>
            </Button>
            <Button Style="{StaticResource DangerSolidBtn}" HorizontalAlignment="Stretch" ToolTipService.ToolTip="Permanently remove this VM (stops first if running)" Command="{Binding DeleteVmCommand}" CommandParameter="{Binding SelectedVm}">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" />
                <TextBlock Text="Delete VM" />
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>
  </Grid>
</UserControl>