<UserControl x:Class="HyperVMManager.Controls.VmActionsPanel" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Focusable="False" SnapsToDevicePixels="True" xmlns:controls="clr-namespace:HyperVMManager.Controls;assembly=HyperVMManager">
  <FrameworkElement.Resources>
    <ResourceDictionary>
      <Style x:Key="VmActBtn" TargetType="{x:Type Button}">
        <Setter Property="Background" Value="#00FFFFFF" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FrameworkElement.Cursor" Value="Hand" />
        <Setter Property="FrameworkElement.FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Foreground" Value="#B1BAC4" />
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type Button}">
              <Border Name="Bd" Background="#00FFFFFF" CornerRadius="6" Padding="6,5">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="UIElement.IsMouseOver" Value="True">
                  <Setter TargetName="Bd" Property="Border.Background" Value="#252b35" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="UIElement.Opacity" Value="0.5" />
                  <Setter Property="FrameworkElement.Cursor" Value="No" />
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="VmActStart" TargetType="{x:Type Button}" BasedOn="{StaticResource VmActBtn}">
        <Style.Triggers>
          <Trigger Property="UIElement.IsMouseOver" Value="True">
            <Setter Property="Foreground" Value="#3FB950" />
          </Trigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="VmActStop" TargetType="{x:Type Button}" BasedOn="{StaticResource VmActBtn}">
        <Style.Triggers>
          <Trigger Property="UIElement.IsMouseOver" Value="True">
            <Setter Property="Foreground" Value="#F85149" />
          </Trigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="VmActRestart" TargetType="{x:Type Button}" BasedOn="{StaticResource VmActBtn}">
        <Style.Triggers>
          <Trigger Property="UIElement.IsMouseOver" Value="True">
            <Setter Property="Foreground" Value="#58A6FF" />
          </Trigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="VmActDelete" TargetType="{x:Type Button}" BasedOn="{StaticResource VmActBtn}">
        <Style.Triggers>
          <Trigger Property="UIElement.IsMouseOver" Value="True">
            <Setter Property="Foreground" Value="#DA3633" />
          </Trigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </FrameworkElement.Resources>
  <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
    <Button Style="{StaticResource VmActStart}" ToolTipService.ToolTip="Start" Command="{Binding DataContext.StartVmCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
      <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
    </Button>
    <Button Style="{StaticResource VmActStop}" Margin="2,0,0,0" ToolTipService.ToolTip="Stop (turn off)" Command="{Binding DataContext.StopVmCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
      <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
    </Button>
    <Button Style="{StaticResource VmActRestart}" Margin="2,0,0,0" ToolTipService.ToolTip="Restart" Command="{Binding DataContext.RestartVmCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
      <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
    </Button>
    <Button Style="{StaticResource VmActDelete}" Margin="2,0,0,0" ToolTipService.ToolTip="Delete virtual machine…" Command="{Binding DataContext.DeleteVmCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
      <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
    </Button>
  </StackPanel>
</UserControl>